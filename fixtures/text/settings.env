# settings.env — KEY=value fixture for plain-text path testing.
# Note: .env has no CodeMirror language mode — verifies backend plain-text
# code path. Open in editor to confirm no syntax coloring applied.

# --- Application ---
APP_NAME=filebrowser
APP_VERSION=1.4.0
APP_ENV=production
APP_DEBUG=false
APP_PORT=58080
APP_HOST=0.0.0.0

# --- Authentication ---
AUTH_ENABLED=true
AUTH_BYPASS=false
SESSION_SECRET=change-me-before-deploying-this-is-not-a-real-secret
SESSION_MAX_AGE=86400
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

# --- Storage ---
STORAGE_ROOT=/srv/files
STORAGE_MAX_UPLOAD_MB=50
STORAGE_HIDDEN_PATTERNS=.*,__pycache__,*.pyc

# --- Terminal ---
TERMINAL_ENABLED=true
TERMINAL_SHELL=/bin/bash
TERMINAL_TIMEOUT=3600

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/filebrowser.log
LOG_MAX_SIZE_MB=10
LOG_KEEP=5

# --- Database (optional future use) ---
# DATABASE_URL=postgresql://user:pass@localhost/filebrowser
# REDIS_URL=redis://localhost:6379/0
