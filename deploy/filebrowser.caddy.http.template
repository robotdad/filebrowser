http://FILEBROWSER_FQDN:FILEBROWSER_CADDY_PORT {
    # All requests (including WebSocket upgrades) are validated by frontdoor.
    # Frontdoor's forward_auth handles both HTTP and WebSocket via
    # GET /api/auth/validate and WS /api/auth/validate respectively.
    forward_auth localhost:FRONTDOOR_PORT {
        uri /api/auth/validate
        copy_headers X-Authenticated-User
    }

    reverse_proxy localhost:FILEBROWSER_PORT
}
